{
  "name": "credit-card-validator",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "concurrently --names server,client --prefix-colors blue,green \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter @cc-validator/server dev",
    "dev:client": "pnpm --filter @cc-validator/client dev",
    "build": "pnpm --recursive run build",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
